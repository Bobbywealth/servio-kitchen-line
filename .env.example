# Servio Kitchen Line — environment variables
# This is a static file server. No database connection is needed.
# Recipe data is fetched from the main Servio backend API.

# Server port (Render sets PORT automatically)
PORT=5001

# Optional: comma-separated list of allowed CORS origins.
# Defaults to all *.onrender.com domains + localhost if not set.
# Example: ALLOWED_ORIGINS=https://servio-app.onrender.com,https://example.com
# ALLOWED_ORIGINS=
